# exiftool_phototools.config — registers the XMP-phototools custom namespace.
#
# See docs/xmp-schema.md for the human-readable spec. Two stanzas are
# required: the first registers the namespace package; the second
# registers writable fields inside it.
#
# Usage:
#   exiftool -config /path/to/exiftool_phototools.config -XMP-phototools:... FILE
#
# src/photo_tools/helpers.py points exiftool at this file automatically.

%Image::ExifTool::XMP::phototools = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-phototools', 2 => 'Image' },
    NAMESPACE => { 'phototools' => 'https://github.com/j23n/photo-tools/ns/1.0/' },
    WRITABLE  => 'string',
);

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::phototools' => {
        # Sentinel + provenance.
        TaggerVersion => { Writable => 'string' },  # "YYYY.N"; presence = "tagged"
        TaggedAt      => { Writable => 'string' },  # ISO 8601 UTC timestamp

        # Geocoder-derived country code (ISO 3166-1 alpha-2, uppercase).
        # Kept out of the keyword space; the country name lives in
        # digiKam:TagsList as Places/<Country>/...
        CountryCode   => { Writable => 'string' },

        # PaddleOCR detected text (bag of strings, one per phrase).
        OCRText       => { List => 'Bag', Writable => 'string' },

        # OCR provenance: ISO 8601 UTC timestamp of last OCR run. Distinct from
        # OCRText because a Bag deleted by `-OCRText=` is indistinguishable from
        # never-written, so we need a separate marker to mean "ran, no text".
        OCRRan        => { Writable => 'string' },

        # CLIP embedding cache (used by `duplicates`).
        CLIPEmbedding => { Writable => 'string' },  # base64 of float32 vector
        CLIPModel     => { Writable => 'string' },  # e.g. ViT-B-32/laion2b_s34b_b79k

        # Provenance for `dates backfill`: which source produced the date
        # written into DateTimeOriginal/CreateDate. Examples:
        # "filename:whatsapp", "filename:signal", "mtime".
        DateBackfilledFrom => { Writable => 'string' },
    },
);

1;
