# exiftool_phototools.config — registers the XMP-phototools custom namespace.
#
# See docs/xmp-schema.md for the human-readable spec; this file is the
# machine-readable registration that exiftool needs in order to read or write
# the namespace fields by name. Without this config the raw XMP is still
# preserved on disk, but exiftool falls back to type Unknown and the field
# names are not surfaced.
#
# Usage:
#   exiftool -config /path/to/exiftool_phototools.config -XMP-phototools:... FILE
#
# The Python code in src/photo_tools/helpers.py points exiftool at this file
# automatically when reading or writing photo-tools fields.
#
# Why two stanzas?
# ExifTool's GetTagTable looks up %Image::ExifTool::XMP::phototools before it
# merges UserDefined entries, so a UserDefined-only config fails with
# "Can't find table". The first stanza seeds the package table; the second
# registers individual writable tags inside it.

# ---------------------------------------------------------------------------
# Stanza 1 — seed the package table (must exist for GetTagTable to find it).
# ---------------------------------------------------------------------------
%Image::ExifTool::XMP::phototools = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-phototools', 2 => 'Image' },
    NAMESPACE => { 'phototools' => 'https://github.com/j23n/photo-tools/ns/1.0/' },
    WRITABLE  => 'string',
);

# ---------------------------------------------------------------------------
# Stanza 2 — register the writable fields. See docs/xmp-schema.md §1.2.
# ---------------------------------------------------------------------------
%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::phototools' => {
        # Sentinel + provenance.
        TaggerVersion => { Writable => 'string' },  # "YYYY.N"; presence = "tagged"
        TaggedAt      => { Writable => 'string' },  # ISO 8601 UTC timestamp

        # Geocoder-derived country code (ISO 3166-1 alpha-2, uppercase).
        # Kept out of the keyword space; the country name lives in
        # digiKam:TagsList as Places/<Country>/...
        CountryCode   => { Writable => 'string' },

        # CLIP embedding cache (used by find-similar).
        CLIPEmbedding => { Writable => 'string' },  # base64 of float32 vector
        CLIPModel     => { Writable => 'string' },  # e.g. ViT-B-32/laion2b_s34b_b79k
    },
);

1;
