# ExifTool config defining the XMP-phototools namespace.
# Used to ensure CLIP embedding metadata is properly preserved
# across multiple exiftool invocations and external tools.
#
# The table must be defined directly as a package variable — ExifTool's
# GetTagTable looks up %Image::ExifTool::XMP::phototools before it merges
# UserDefined entries, so a UserDefined-only config fails with
# "Can't find table".

# Seed the package table so GetTagTable finds it (must be non-empty).
%Image::ExifTool::XMP::phototools = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-phototools', 2 => 'Image' },
    NAMESPACE => { 'phototools' => 'http://ns.photo-tools/1.0/' },
    WRITABLE  => 'string',
);

# Register the writable tags via UserDefined (processed after table lookup).
%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::phototools' => {
        CLIPEmbedding => { Writable => 'string' },
        CLIPModel     => { Writable => 'string' },
        CLIPTimestamp => { Writable => 'string' },
    },
);

1;
